# ===== Telegram =====
TELEGRAM_BOT_TOKEN=123456:replace-me

# ===== OpenAI =====
OPENAI_API_KEY=sk-replace-me
# Model used to GENERATE fresh exams
OPENAI_GEN_MODEL=gpt-4o
# Vision model used to OCR scanned past-exam PDFs during ingestion
OPENAI_OCR_MODEL=gpt-4o

# ===== Database =====
# Used by the app (async driver) and by docker-compose
POSTGRES_USER=exambot
POSTGRES_PASSWORD=exambot_secret
POSTGRES_DB=exambot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== App =====
# Default exam settings
DEFAULT_NUM_QUESTIONS=30
# Comma-separated minute options offered to the user
TIME_OPTIONS_MINUTES=10,15,20,30
LOG_LEVEL=INFO
